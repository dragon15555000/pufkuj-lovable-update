# === 1koszyk API (server-side) ===
# Panel 1koszyk → Konfiguracja → API
ONECART_API_KEY=
ONECART_CLIENT_ID=
ONECART_API_URL=https://api.1cart.eu/v1

# === 1koszyk embed widget (client-side, opcjonalne) ===
# Oficjalny snippet z panelu 1koszyk → Konfiguracja → Integracje → Widget koszyka.
# Jeśli ustawione, w <head> zostanie wstrzyknięte:
#   <script id="onecart" src="<VITE_ONECART_EMBED_SRC>" async></script>
#
# Obecnie Pufki używają darmowego planu 1koszyk, więc domyślnym adresem jest
# pufka.1ct.eu. Własna domena koszyk.pufkuj.pl to przyszła opcja, która wymaga
# odpowiedniego planu 1koszyk i ręcznej konfiguracji DNS/Turnstile.
# Patrz docs/1koszyk-branding.md, sekcja 8.
VITE_ONECART_EMBED_SRC=https://pufka.1ct.eu/assets/front/embeded.bundle.js
# Przyszła własna domena (wymaga płatnego planu 1koszyk + konfiguracji):
# VITE_ONECART_EMBED_SRC=https://koszyk.pufkuj.pl/assets/front/embeded.bundle.js

# === Facebook / Meta Pixel — weryfikacja domeny ===
# Skąd wziąć: panel 1koszyk → Konfiguracja → Integracje → Usługi →
# Facebook/Meta Pixel → "Kod weryfikacyjny domeny".
# Jeśli ustawione, w <head> pojawi się:
#   <meta name="facebook-domain-verification" content="<wartość>" />
VITE_FACEBOOK_DOMAIN_VERIFICATION=
